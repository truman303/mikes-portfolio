---
import DarkModeToggle from './DarkModeToggle.astro';

const navItems = [
  { label: 'Mike Fellowes', href: '#mike' },
  { label: 'Work', href: '#work' },
  { label: 'Delivery', href: '#delivery' },
  { label: 'Brands', href: '#brands' },
  { label: 'Contact', href: '#contact' },
];
---

<header class="site-header">
  <div class="header-inner">
    <div class="header-left">
      <div class="profile-badge">
        <button
          class="profile-image profile-trigger"
          type="button"
          aria-label="View full profile picture"
        >
          <img
            src="/profile-small.png"
            alt="Profile picture of Mike Fellowes"
            class="brand-logo"
            width="64"
            height="64"
            loading="lazy"
            decoding="async"
          />
        </button>
        <p class="profile-subcopy">
            Track record of delivering mission critical systems that stand the test of time.
        </p>
    </div>
  </div>

    <div class="header-right">
      <nav class="nav-desktop" aria-label="Main navigation">
        <ul class="nav-list">
          {navItems.map(({ label, href }) => (
            <li>
              <a class="nav-link" href={href}>{label}</a>
            </li>
          ))}
        </ul>
      </nav>

      <DarkModeToggle />

      <button
        class="hamburger"
        type="button"
        aria-label="Open menu"
        aria-expanded="false"
        aria-controls="mobile-menu"
      >
        <span class="hamburger-line"></span>
        <span class="hamburger-line"></span>
        <span class="hamburger-line"></span>
      </button>
    </div>
  </div>

  <nav id="mobile-menu" class="nav-mobile" aria-label="Mobile navigation">
    <ul class="nav-mobile-list">
      {navItems.map(({ label, href }) => (
        <li>
          <a class="nav-mobile-link" href={href}>{label}</a>
        </li>
      ))}
    </ul>
  </nav>
</header>

<div class="profile-lightbox" id="profile-lightbox" role="dialog" aria-modal="true" aria-label="Profile picture">
  <div class="lightbox-backdrop"></div>
  <div class="lightbox-frame">
    <img
      src="/profile-large.png"
      alt="Mike Fellowes"
      class="lightbox-photo"
      width="400"
      height="400"
    />
    <button class="lightbox-close" type="button" aria-label="Close">
      <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
        <line x1="6" y1="6" x2="18" y2="18" />
        <line x1="18" y1="6" x2="6" y2="18" />
      </svg>
    </button>
  </div>
</div>

<script>
  import gsap from 'gsap';

  function initMobileMenu() {
    const hamburger = document.querySelector('.hamburger');
    const mobileMenu = document.getElementById('mobile-menu');
    if (!hamburger || !mobileMenu) return;

    hamburger.addEventListener('click', () => {
      const isOpen = hamburger.getAttribute('aria-expanded') === 'true';
      hamburger.setAttribute('aria-expanded', String(!isOpen));
      mobileMenu.classList.toggle('is-open', !isOpen);
      document.body.classList.toggle('menu-open', !isOpen);
    });

    mobileMenu.querySelectorAll('a').forEach((link) => {
      link.addEventListener('click', () => {
        hamburger.setAttribute('aria-expanded', 'false');
        mobileMenu.classList.remove('is-open');
        document.body.classList.remove('menu-open');
      });
    });
  }

  function initProfileLightbox() {
    const trigger = document.querySelector('.profile-trigger') as HTMLElement | null;
    const lightbox = document.getElementById('profile-lightbox');
    const backdrop = lightbox?.querySelector('.lightbox-backdrop') as HTMLElement | null;
    const frame = lightbox?.querySelector('.lightbox-frame') as HTMLElement | null;
    const closeBtn = lightbox?.querySelector('.lightbox-close') as HTMLElement | null;
    if (!trigger || !lightbox || !backdrop || !frame || !closeBtn) return;

    let isOpen = false;

    function open() {
      if (isOpen) return;
      isOpen = true;
      lightbox!.classList.add('is-visible');
      document.body.style.overflow = 'hidden';

      const tl = gsap.timeline();
      tl.fromTo(backdrop!, { autoAlpha: 0 }, { autoAlpha: 1, duration: 0.3, ease: 'power2.out' })
        .fromTo(
          frame!,
          { autoAlpha: 0, scale: 0.6, rotation: -3 },
          { autoAlpha: 1, scale: 1, rotation: 0, duration: 0.45, ease: 'back.out(1.4)' },
          '-=0.15'
        )
        .fromTo(
          closeBtn!,
          { autoAlpha: 0, y: -10 },
          { autoAlpha: 1, y: 0, duration: 0.25, ease: 'power2.out' },
          '-=0.15'
        );
    }

    function close() {
      if (!isOpen) return;
      isOpen = false;

      const tl = gsap.timeline({
        onComplete: () => {
          lightbox!.classList.remove('is-visible');
          document.body.style.overflow = '';
        },
      });
      tl.to(frame!, { autoAlpha: 0, scale: 0.85, rotation: 2, duration: 0.25, ease: 'power2.in' })
        .to(backdrop!, { autoAlpha: 0, duration: 0.2, ease: 'power2.in' }, '-=0.1');
    }

    trigger.addEventListener('click', open);
    backdrop.addEventListener('click', close);
    closeBtn.addEventListener('click', close);
    document.addEventListener('keydown', (e) => {
      if (e.key === 'Escape' && isOpen) close();
    });
  }

  initMobileMenu();
  initProfileLightbox();
  document.addEventListener('astro:after-swap', () => {
    initMobileMenu();
    initProfileLightbox();
  });
</script>

<style>
  .site-header {
    position: fixed;
    top: 0;
    left: 0;
    right: 0;
    z-index: 100;
    height: var(--header-height);
    background-color: var(--color-bg);
    border-bottom: var(--border-sketch);
    transition: background-color 0.3s ease;
  }

  .header-inner {
    display: flex;
    align-items: center;
    justify-content: space-between;
    max-width: 1200px;
    margin: 0 auto;
    height: 100%;
    padding: 0 var(--space-lg);
  }

  /* --- Left: Profile badge --- */

  .header-left {
    flex-shrink: 0;
  }

  .profile-badge {
    display: flex;
    align-items: center;
    gap: var(--space-md);
  }

  .profile-image {
    width: 44px;
    height: 44px;
    border-radius: 50%;
    border: var(--border-sketch);
    display: flex;
    align-items: center;
    justify-content: center;
    flex-shrink: 0;
    overflow: hidden;
  }

  .profile-trigger {
    background: none;
    padding: 0;
    cursor: pointer;
    transition: transform 0.2s ease, box-shadow 0.2s ease;
  }

  .profile-trigger:hover {
    transform: scale(1.08);
    box-shadow: 3px 3px 0 var(--color-border);
  }

  .profile-trigger:active {
    transform: scale(0.96);
  }

  .profile-image svg {
    width: 30px;
    height: 30px;
  }

  .profile-subcopy {
    font-size: var(--font-size-xs);
    color: var(--color-text-muted);
    max-width: 280px;
    line-height: 1.35;
    display: none;
  }

  @media (min-width: 900px) {
    .profile-subcopy {
      display: block;
    }
  }

  /* --- Right: Nav + toggle + hamburger --- */

  .header-right {
    display: flex;
    align-items: center;
    gap: var(--space-sm);
  }

  /* Desktop nav */

  .nav-desktop {
    display: none;
  }

  @media (min-width: 768px) {
    .nav-desktop {
      display: block;
    }
  }

  .nav-list {
    display: flex;
    list-style: none;
    gap: var(--space-xs);
  }

  .nav-link {
    display: block;
    padding: var(--space-xs) var(--space-sm);
    font-size: var(--font-size-sm);
    color: var(--color-text);
    border-radius: var(--radius-sketch);
    transition: color 0.2s ease, background-color 0.2s ease;
    text-decoration: none;
  }

  .nav-link:hover {
    color: var(--color-accent);
    background-color: var(--color-bg-alt);
    text-decoration: none;
  }

  /* Hamburger (mobile only) */

  .hamburger {
    display: flex;
    flex-direction: column;
    justify-content: center;
    gap: 5px;
    background: none;
    border: none;
    cursor: pointer;
    padding: var(--space-sm);
    width: 38px;
    height: 38px;
  }

  @media (min-width: 768px) {
    .hamburger {
      display: none;
    }
  }

  .hamburger-line {
    display: block;
    width: 22px;
    height: 2px;
    background-color: var(--color-text);
    border-radius: 1px;
    transition: transform 0.25s ease, opacity 0.2s ease;
    transform-origin: center;
  }

  .hamburger[aria-expanded='true'] .hamburger-line:nth-child(1) {
    transform: translateY(7px) rotate(45deg);
  }

  .hamburger[aria-expanded='true'] .hamburger-line:nth-child(2) {
    opacity: 0;
  }

  .hamburger[aria-expanded='true'] .hamburger-line:nth-child(3) {
    transform: translateY(-7px) rotate(-45deg);
  }

  /* Mobile menu */

  .nav-mobile {
    position: fixed;
    top: var(--header-height);
    left: 0;
    right: 0;
    background-color: var(--color-bg);
    border-bottom: var(--border-sketch);
    padding: var(--space-lg);
    transform: translateY(-100%);
    opacity: 0;
    pointer-events: none;
    transition: transform 0.3s ease, opacity 0.3s ease;
    z-index: 99;
  }

  .nav-mobile.is-open {
    transform: translateY(0);
    opacity: 1;
    pointer-events: auto;
  }

  @media (min-width: 768px) {
    .nav-mobile {
      display: none;
    }
  }

  .nav-mobile-list {
    list-style: none;
    display: flex;
    flex-direction: column;
    gap: var(--space-sm);
  }

  .nav-mobile-link {
    display: block;
    padding: var(--space-sm) var(--space-md);
    font-size: var(--font-size-lg);
    color: var(--color-text);
    border-radius: var(--radius-sketch);
    transition: color 0.2s ease, background-color 0.2s ease;
    text-decoration: none;
  }

  .nav-mobile-link:hover {
    color: var(--color-accent);
    background-color: var(--color-bg-alt);
    text-decoration: none;
  }

  /* Prevent body scroll when menu is open */
  :global(body.menu-open) {
    overflow: hidden;
  }

  /* --- Profile Lightbox --- */

  :global(.profile-lightbox) {
    position: fixed;
    inset: 0;
    z-index: 200;
    display: none;
    place-items: center;
  }

  :global(.profile-lightbox.is-visible) {
    display: grid;
  }

  :global(.lightbox-backdrop) {
    position: absolute;
    inset: 0;
    background: rgba(0, 0, 0, 0.55);
    backdrop-filter: blur(6px);
    -webkit-backdrop-filter: blur(6px);
    visibility: hidden;
    cursor: pointer;
  }

  :global(.lightbox-frame) {
    position: relative;
    border: 3px solid var(--color-border);
    border-radius: var(--radius-sketch);
    box-shadow: 4px 4px 0 var(--color-border);
    background: var(--color-card-bg);
    padding: 6px;
    max-width: min(400px, 85vw);
    max-height: 85vh;
    visibility: hidden;
  }

  :global(.lightbox-photo) {
    display: block;
    width: 100%;
    height: auto;
    border-radius: var(--radius-sketch);
  }

  :global(.lightbox-close) {
    position: absolute;
    top: -14px;
    right: -14px;
    width: 32px;
    height: 32px;
    border-radius: 50%;
    border: 2px solid var(--color-border);
    background: var(--color-bg);
    color: var(--color-text);
    display: grid;
    place-items: center;
    cursor: pointer;
    box-shadow: 2px 2px 0 var(--color-border);
    transition: transform 0.15s ease, background-color 0.15s ease;
    visibility: hidden;
    padding: 0;
  }

  :global(.lightbox-close:hover) {
    transform: scale(1.12) rotate(90deg);
    background: var(--color-accent);
    color: #fff;
  }
</style>
