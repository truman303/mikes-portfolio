---
import WavingFigure from '../svg/figures/WavingFigure.astro';

const links = [
  {
    label: 'LinkedIn',
    href: 'https://www.linkedin.com/in/mikefellowes/',
    desc: 'Connect with me',
  },
  {
    label: 'GitHub',
    href: 'https://github.com/mikefellows',
    desc: 'Browse my code',
  },
  {
    label: 'App Frameworks',
    href: 'https://applicationframeworks.com',
    desc: 'My consultancy',
  },
];

const currentYear = new Date().getFullYear();
---

<section id="contact" class="section contact-section">
  <div class="container contact-container">

    <div class="contact-header">
      <h2 class="section-title contact-title">Let's Connect</h2>
      <p class="contact-subtitle">Got an idea, a project, or just want to say hello? Find me here.</p>
      <svg class="contact-divider" viewBox="0 0 120 8" aria-hidden="true">
        <path d="M2 5 Q15 1 30 4 Q50 8 70 3 Q90 0 105 5 Q112 7 118 4" />
      </svg>
    </div>

    <div class="contact-links" role="list">
      {links.map(({ label, href, desc }, i) => (
        <a
          class="contact-card"
          href={href}
          target="_blank"
          rel="noopener noreferrer"
          aria-label={`${label} — ${desc}`}
          role="listitem"
          data-index={i}
        >
          <div class="card-icon" aria-hidden="true">
            {label === 'LinkedIn' && (
              <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 64 64" class="stick-figure">
                <circle cx="22" cy="14" r="8" />
                <circle cx="22" cy="14" r="3" fill="currentColor" stroke="none" />
                <line x1="22" y1="22" x2="22" y2="44" />
                <path d="M22 30 Q22 28 30 28 Q38 28 38 36 L38 44" />
                <circle cx="44" cy="14" r="8" />
                <circle cx="44" cy="14" r="3" fill="currentColor" stroke="none" />
                <line x1="44" y1="22" x2="44" y2="44" />
                <path d="M44 30 Q44 28 52 28 Q58 28 58 36 L58 44" />
                <path d="M28 52 Q38 48 48 52" stroke-dasharray="3 2" opacity="0.5" />
              </svg>
            )}
            {label === 'GitHub' && (
              <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 64 64" class="stick-figure">
                <path d="M14 22 L6 34 L14 46" />
                <path d="M50 22 L58 34 L50 46" />
                <line x1="28" y1="20" x2="36" y2="48" />
                <path d="M22 54 Q32 50 42 54 Q52 58 56 52" stroke-dasharray="3 2" />
                <circle cx="18" cy="8" r="4" />
                <line x1="18" y1="12" x2="18" y2="16" />
                <path d="M18 14 Q24 14 28 20" stroke-dasharray="2 2" opacity="0.4" />
                <circle cx="46" cy="8" r="4" />
                <line x1="46" y1="12" x2="46" y2="16" />
                <path d="M46 14 Q40 14 36 20" stroke-dasharray="2 2" opacity="0.4" />
              </svg>
            )}
            {label === 'App Frameworks' && (
              <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 64 64" class="stick-figure">
                <rect x="12" y="8" width="40" height="32" rx="3" />
                <line x1="12" y1="18" x2="52" y2="18" />
                <circle cx="18" cy="13" r="2" fill="currentColor" stroke="none" />
                <circle cx="24" cy="13" r="2" fill="currentColor" stroke="none" />
                <circle cx="30" cy="13" r="2" fill="currentColor" stroke="none" />
                <rect x="18" y="23" width="12" height="12" rx="1" />
                <rect x="34" y="23" width="12" height="6" rx="1" />
                <rect x="34" y="32" width="12" height="3" rx="1" />
                <path d="M8 40 L56 40 L52 46 L12 46 Z" />
                <path d="M22 52 Q32 56 42 52" opacity="0.4" />
              </svg>
            )}
          </div>
          <span class="card-label">{label}</span>
          <span class="card-desc">{desc}</span>
          <svg class="card-arrow" viewBox="0 0 24 24" aria-hidden="true">
            <path d="M5 12 L18 12" />
            <path d="M14 7 L19 12 L14 17" />
          </svg>
        </a>
      ))}
    </div>

    <div class="contact-figure" aria-hidden="true">
      <div class="figure-wrap">
        <WavingFigure />
      </div>
      <p class="figure-caption">Thanks for visiting!</p>
    </div>
  </div>

  <footer class="site-footer">
    <svg class="footer-divider" viewBox="0 0 300 8" preserveAspectRatio="none" aria-hidden="true">
      <path d="M0 4 Q30 0 60 4 Q90 8 120 4 Q150 0 180 4 Q210 8 240 4 Q270 0 300 4" />
    </svg>
    <p class="footer-copy">&copy; {currentYear} Mike Fellowes. Sketched with care.</p>
  </footer>
</section>

<style>
  .contact-section {
    display: flex;
    flex-direction: column;
    justify-content: center;
    min-height: 100vh;
    padding-top: var(--space-2xl);
    padding-bottom: 0;
    background-color: var(--color-bg);
  }

  .contact-container {
    flex: 1;
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    gap: var(--space-xl);
  }

  /* --- Header --- */

  .contact-header {
    text-align: center;
    max-width: 520px;
  }

  .contact-title {
    margin-bottom: var(--space-sm);
  }

  .contact-subtitle {
    font-size: var(--font-size-lg);
    color: var(--color-text-muted);
    line-height: 1.5;
  }

  .contact-divider {
    display: block;
    width: 100px;
    height: 8px;
    margin: var(--space-lg) auto 0;
    stroke: var(--color-accent);
    fill: none;
    stroke-width: 1.5;
    stroke-linecap: round;
    opacity: 0.5;
  }

  /* --- Contact cards --- */

  .contact-links {
    display: flex;
    gap: var(--space-lg);
    justify-content: center;
    flex-wrap: wrap;
    width: 100%;
    max-width: 900px;
  }

  .contact-card {
    flex: 1 1 240px;
    max-width: 280px;
    display: flex;
    flex-direction: column;
    align-items: center;
    text-align: center;
    gap: var(--space-sm);
    padding: var(--space-xl) var(--space-lg) var(--space-lg);
    background: var(--color-card-bg);
    border: var(--border-sketch);
    border-radius: var(--radius-sketch);
    box-shadow: var(--shadow-sketch);
    color: var(--color-text);
    text-decoration: none;
    transition: transform 0.3s ease, box-shadow 0.3s ease, border-color 0.3s ease;
    position: relative;
    cursor: pointer;
  }

  .contact-card:hover {
    transform: translateY(-6px) rotate(0deg) !important;
    box-shadow: 3px 5px 0 var(--color-accent);
    border-color: var(--color-accent);
    text-decoration: none;
  }

  .contact-card:focus-visible {
    outline: 2px solid var(--color-accent);
    outline-offset: 3px;
  }

  .contact-card[data-index="0"] { transform: rotate(-1.3deg); }
  .contact-card[data-index="1"] { transform: rotate(0.9deg); }
  .contact-card[data-index="2"] { transform: rotate(-0.7deg); }

  /* Card icon */

  .card-icon {
    width: 64px;
    height: 64px;
    display: flex;
    align-items: center;
    justify-content: center;
    margin-bottom: var(--space-xs);
  }

  .card-icon :global(svg) {
    width: 100%;
    height: 100%;
  }

  /* Card label */

  .card-label {
    font-size: var(--font-size-2xl);
    line-height: 1;
    color: var(--color-text);
    transition: color 0.25s ease;
  }

  .contact-card:hover .card-label {
    color: var(--color-accent);
  }

  .card-desc {
    font-size: var(--font-size-sm);
    color: var(--color-text-muted);
    line-height: 1.4;
  }

  /* Card arrow */

  .card-arrow {
    width: 24px;
    height: 24px;
    stroke: var(--color-text-muted);
    fill: none;
    stroke-width: 2;
    stroke-linecap: round;
    stroke-linejoin: round;
    margin-top: var(--space-xs);
    transition: transform 0.25s ease, stroke 0.25s ease;
  }

  .contact-card:hover .card-arrow {
    transform: translateX(4px);
    stroke: var(--color-accent);
  }

  /* --- Waving goodbye figure --- */

  .contact-figure {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: var(--space-sm);
    margin-top: var(--space-md);
  }

  .figure-wrap {
    width: 80px;
    height: 110px;
  }

  .figure-wrap :global(svg) {
    width: 100%;
    height: 100%;
  }

  .figure-caption {
    font-size: var(--font-size-sm);
    color: var(--color-text-muted);
    letter-spacing: 0.03em;
  }

  /* --- Footer --- */

  .site-footer {
    width: 100%;
    text-align: center;
    padding: var(--space-lg) var(--space-lg) var(--space-xl);
    margin-top: auto;
  }

  .footer-divider {
    display: block;
    width: 100%;
    max-width: 600px;
    height: 6px;
    margin: 0 auto var(--space-lg);
    stroke: var(--color-border);
    fill: none;
    stroke-width: 1;
    stroke-linecap: round;
    opacity: 0.15;
  }

  .footer-copy {
    font-size: var(--font-size-xs);
    color: var(--color-text-muted);
    letter-spacing: 0.02em;
  }

  /* --- Responsive --- */

  @media (max-width: 768px) {
    .contact-section {
      padding-top: var(--space-xl);
      min-height: auto;
    }

    .contact-container {
      gap: var(--space-lg);
    }

    .contact-links {
      flex-direction: column;
      align-items: center;
      gap: var(--space-md);
    }

    .contact-card {
      max-width: 320px;
      width: 100%;
      flex: none;
      padding: var(--space-lg) var(--space-md);
    }

    .contact-card[data-index="0"],
    .contact-card[data-index="1"],
    .contact-card[data-index="2"] {
      transform: none;
    }

    .card-icon {
      width: 52px;
      height: 52px;
    }

    .card-label {
      font-size: var(--font-size-xl);
    }

    .figure-wrap {
      width: 64px;
      height: 90px;
    }
  }

  /* --- Reduced motion --- */

  @media (prefers-reduced-motion: reduce) {
    .contact-card {
      transition: none;
    }

    .card-arrow {
      transition: none;
    }
  }
</style>
