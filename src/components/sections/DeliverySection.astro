<style>
  .delivery-section {
    position: relative;
    padding: 0;
    min-height: 100vh;
  }

  .delivery-layout {
    height: 100vh;
    display: flex;
    flex-direction: column;
    overflow: hidden;
  }

  /* --- Header row --- */

  .delivery-header {
    padding-top: calc(var(--header-height) + var(--space-lg));
    padding-bottom: var(--space-sm);
    flex-shrink: 0;
  }

  .delivery-title {
    margin-bottom: 0;
  }

  .delivery-tagline {
    font-size: var(--font-size-base);
    color: var(--color-text-muted);
    margin-top: var(--space-xs);
  }

  /* Sketch divider */
  .delivery-header::after {
    content: '';
    display: block;
    width: 80px;
    height: 2px;
    margin-top: var(--space-md);
    margin-left: var(--space-lg);
    background: var(--color-border);
    opacity: 0.2;
    border-radius: 1px;
  }

  /* --- Horizontal card track --- */

  .delivery-track {
    flex: 1;
    display: flex;
    align-items: center;
    gap: var(--space-lg);
    padding: var(--space-md) 0 var(--space-md) var(--space-xl);
    min-height: 0;
  }

  .delivery-track::after {
    content: '';
    flex-shrink: 0;
    width: var(--space-xl);
    min-height: 1px;
  }

  /* --- Mobile fallback --- */

  @media (max-width: 768px) {
    .delivery-layout {
      height: auto;
      overflow: visible;
    }

    .delivery-header {
      padding-top: var(--space-xl);
    }

    .delivery-track {
      flex-direction: column;
      align-items: stretch;
      padding: var(--space-lg);
      gap: var(--space-lg);
    }

    .delivery-track::after {
      display: none;
    }

    .delivery-header::after {
      margin-left: 0;
    }
  }

  /* --- Reduced-motion fallback (desktop) --- */

  @media (prefers-reduced-motion: reduce) and (min-width: 769px) {
    .delivery-layout {
      height: auto;
      overflow: visible;
    }

    .delivery-track {
      flex-wrap: wrap;
      justify-content: center;
      padding: var(--space-lg);
      gap: var(--space-lg);
    }

    .delivery-track::after {
      display: none;
    }
  }
</style>
