---
import UtilitiesScene from '../svg/scenes/UtilitiesScene.astro';
import PaymentsScene from '../svg/scenes/PaymentsScene.astro';
import ITManagementScene from '../svg/scenes/ITManagementScene.astro';
import DefenseScene from '../svg/scenes/DefenseScene.astro';
import AgentSkillsScene from '../svg/scenes/AgentSkillsScene.astro';

const domains = [
  {
    id: 'utilities',
    num: '01',
    title: 'Utilities',
    desc: 'Electricity, water & gas metering systems, revenue collection and the integrations that connect them all - STS/NRS/CIM/MDM/ERP/CRM.',
  },
  {
    id: 'payments',
    num: '02',
    title: 'Payments',
    desc: 'Point-of-sale, smart cards, NFC and prepayment systems — making every transaction seamless.',
  },
  {
    id: 'it-management',
    num: '03',
    title: 'IT Service Management',
    desc: 'Building enterprise platforms, portals & the tools that keep systems secure and teams productive - CI/CD, telemetry, monitoring, ticketing...',
  },
  {
    id: 'defense',
    num: '04',
    title: 'Defense & Radio',
    desc: 'Radio spectrum management, electronic warfare systems & licensing infrastructure — securing the airwaves.',
  },
];

const shutterImages: (string | null)[] = [
  '/images/gas.jpg',
  '/images/water.jpg',
  '/images/electricity.jpg',
//   null, // payments — replace with a real image
   '/images/payments.jpg',
//   null, // IT management — replace with a real image
  '/images/it-management.jpg',
//   null, // defense — replace with a real image
  '/images/defense-radio.jpg',
];

const NUM_STRIPS = 8;
---

<section id="work" class="section work-section">
  <div class="work-pinned">

    <div class="work-shutter-bg" aria-hidden="true">
      {shutterImages.map((src, i) => (
        <div
          class:list={['shutter-image', { 'shutter-placeholder': !src }]}
          data-shutter={i}
          style={src ? `background-image: url('${src}')` : undefined}
        />
      ))}
      <div class="shutter-veil" />
      <div class="shutter-strips">
        {Array.from({ length: NUM_STRIPS }).map(() => (
          <div class="shutter-strip" />
        ))}
      </div>
    </div>

    <div class="work-header">
      <div class="container">
        <h2 class="section-title work-title">Work</h2>
        <div class="work-progress" aria-hidden="true">
          {domains.map((_, i) => (
            <span class="work-progress-dot" data-index={i} />
          ))}
        </div>
      </div>
      <div class="container">
        <p class="work-tagline">In my 20+ years developing software, I've worked in exciting domains that have a global impact.</p>
      </div>
    </div>

    <div class="work-stage container">
      <div class="work-domain" data-domain="utilities">
        <div class="domain-title-wrap">
          <span class="domain-num">{domains[0].num}</span>
          <h3 class="domain-heading">{domains[0].title}</h3>
          <p class="domain-desc">{domains[0].desc}</p>
        </div>
        <div class="domain-scene">
          <UtilitiesScene />
        </div>
      </div>

      <div class="work-domain" data-domain="payments">
        <div class="domain-title-wrap">
          <span class="domain-num">{domains[1].num}</span>
          <h3 class="domain-heading">{domains[1].title}</h3>
          <p class="domain-desc">{domains[1].desc}</p>
        </div>
        <div class="domain-scene">
          <PaymentsScene />
        </div>
      </div>

      <div class="work-domain" data-domain="it-management">
        <div class="domain-title-wrap">
          <span class="domain-num">{domains[2].num}</span>
          <h3 class="domain-heading">{domains[2].title}</h3>
          <p class="domain-desc">{domains[2].desc}</p>
        </div>
        <div class="domain-scene">
          <ITManagementScene />
        </div>
      </div>

      <div class="work-domain" data-domain="defense">
        <div class="domain-title-wrap">
          <span class="domain-num">{domains[3].num}</span>
          <h3 class="domain-heading">{domains[3].title}</h3>
          <p class="domain-desc">{domains[3].desc}</p>
        </div>
        <div class="domain-scene">
          <DefenseScene />
        </div>
      </div>
    </div>
  </div>
</section>

<script>
  import '../../scripts/work-scroll';
</script>

<style>
  /* ===== Section shell ===== */

  .work-section {
    position: relative;
    padding: 0;
    min-height: auto;
    background-color: var(--color-bg-alt);
  }

  .work-pinned {
    height: 100vh;
    display: flex;
    flex-direction: column;
    overflow: hidden;
    position: relative;
  }

  /* ===== Shutter background layer ===== */

  .work-shutter-bg {
    position: absolute;
    inset: 0;
    z-index: 0;
    overflow: hidden;
    display: none;
  }

  .shutter-image {
    position: absolute;
    inset: 0;
    background-size: cover;
    background-position: center;
    will-change: opacity;
  }

  .shutter-placeholder[data-shutter="3"] {
    background: linear-gradient(145deg, #2a1810 0%, #5c3a28 40%, #8a6040 70%, #b8935a 100%);
  }

  .shutter-placeholder[data-shutter="4"] {
    background: linear-gradient(145deg, #0a1628 0%, #152a4a 40%, #1e4d6e 70%, #287088 100%);
  }

  .shutter-placeholder[data-shutter="5"] {
    background: linear-gradient(145deg, #101018 0%, #1a1a2e 40%, #2a2a3c 70%, #3a3a4e 100%);
  }

  .shutter-veil {
    position: absolute;
    inset: 0;
    z-index: 1;
    pointer-events: none;
    background: linear-gradient(
      to right,
      rgba(var(--color-bg-alt-rgb), 0.88) 0%,
      rgba(var(--color-bg-alt-rgb), 0.65) 38%,
      rgba(var(--color-bg-alt-rgb), 0.30) 100%
    );
  }

  .shutter-strips {
    position: absolute;
    inset: 0;
    z-index: 2;
    display: flex;
    flex-direction: column;
    pointer-events: none;
  }

  .shutter-strip {
    flex: 1;
    background-color: var(--color-bg-alt);
    transform-origin: center center;
  }

  /* ===== Content layers (above shutter) ===== */

  .work-header {
    padding-top: calc(var(--header-height) + var(--space-lg));
    padding-bottom: var(--space-sm);
    flex-shrink: 0;
    position: relative;
    z-index: 1;
  }

  .work-header .container {
    display: flex;
    align-items: baseline;
    justify-content: space-between;
  }

  .work-title {
    margin-bottom: 0;
  }

  .work-tagline {
    font-size: var(--font-size-base);
    color: var(--color-text-muted);
    margin-top: var(--space-xs);
  }

  /* ===== Progress dots ===== */

  .work-progress {
    display: flex;
    gap: var(--space-sm);
    align-items: center;
  }

  .work-progress-dot {
    width: 8px;
    height: 8px;
    border-radius: 50%;
    border: 1.5px solid var(--color-text-muted);
    background: transparent;
    transition: background-color 0.3s ease, border-color 0.3s ease, transform 0.3s ease;
  }

  .work-progress-dot:global(.is-active) {
    background-color: var(--color-accent);
    border-color: var(--color-accent);
    transform: scale(1.35);
  }

  /* ===== Stage area ===== */

  .work-stage {
    flex: 1;
    position: relative;
    min-height: 0;
    z-index: 1;
  }

  /* ===== Domain panels ===== */

  .work-domain {
    position: absolute;
    inset: 0;
    display: flex;
    align-items: center;
    gap: var(--space-xl);
  }

  .domain-title-wrap {
    flex: 1;
    padding: var(--space-lg);
  }

  .domain-num {
    display: block;
    font-size: var(--font-size-sm);
    color: var(--color-accent);
    letter-spacing: 0.15em;
    margin-bottom: var(--space-xs);
  }

  .domain-heading {
    font-size: clamp(2rem, 5vw, 3.5rem);
    line-height: 1.1;
    color: var(--color-text);
    margin-bottom: var(--space-md);
  }

  .domain-desc {
    font-size: var(--font-size-base);
    color: var(--color-text-muted);
    max-width: 400px;
    line-height: 1.55;
  }

  .domain-scene {
    flex: 1;
    display: flex;
    align-items: center;
    justify-content: center;
    padding: var(--space-lg);
  }

  .domain-scene :global(svg) {
    width: 100%;
    max-width: 380px;
    height: auto;
  }

  /* ===== Sketch divider ===== */

  .work-header::after {
    content: '';
    display: block;
    width: 80px;
    height: 2px;
    margin-top: var(--space-md);
    margin-left: var(--space-lg);
    background: var(--color-border);
    opacity: 0.2;
    border-radius: 1px;
  }

  /* ===== Desktop with motion: enable shutter bg ===== */

  @media (min-width: 769px) and (prefers-reduced-motion: no-preference) {
    .work-section {
      background-color: transparent;
    }

    .work-shutter-bg {
      display: block;
    }
  }

  /* ===== Mobile fallback ===== */

  @media (max-width: 768px) {
    .work-pinned {
      height: auto;
    }

    .work-header {
      padding-top: var(--space-xl);
    }

    .work-stage {
      display: flex;
      flex-direction: column;
      gap: var(--space-xl);
      padding-bottom: var(--space-xl);
    }

    .work-domain {
      position: static;
      flex-direction: column;
      gap: var(--space-md);
      align-items: stretch;
    }

    .domain-title-wrap {
      padding: var(--space-md) 0 0;
    }

    .domain-scene {
      padding: 0;
    }

    .domain-scene :global(svg) {
      max-width: 260px;
    }

    .work-progress {
      display: none;
    }

    .work-header::after {
      margin-left: 0;
    }
  }

  /* ===== Reduced-motion fallback (desktop) ===== */

  @media (prefers-reduced-motion: reduce) and (min-width: 769px) {
    .work-pinned {
      height: auto;
    }

    .work-stage {
      display: flex;
      flex-direction: column;
      gap: var(--space-2xl);
      padding-bottom: var(--space-xl);
    }

    .work-domain {
      position: static;
    }

    .work-progress {
      display: none;
    }
  }
</style>
